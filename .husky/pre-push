echo "Running quality checks before push..."

pnpm --filter @pathfinding/types run build || exit 1

pnpm typecheck || {
  echo "TypeScript check failed. Please fix type errors before pushing."
  exit 1
}

pnpm -r --if-present --filter '!@pathfinding/dashboard' run test || {
  echo "Tests failed. Please fix failing tests before pushing."
  exit 1
}

echo "All quality checks passed!"
