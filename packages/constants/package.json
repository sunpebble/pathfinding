{
  "name": "@pathfinding/constants",
  "type": "module",
  "version": "1.0.0",
  "description": "Shared constants for Pathfinding app",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@pathfinding/types": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.9.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
