{
  "name": "@pathfinding/constants",
  "type": "module",
  "version": "1.0.0",
  "description": "Shared constants for Pathfinding app",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@pathfinding/types": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3"
  }
}
