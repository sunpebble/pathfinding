{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "constants",
  "projectType": "library",
  "sourceRoot": "packages/constants/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsdown",
        "cwd": "packages/constants"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsdown --watch",
        "cwd": "packages/constants"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/constants"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/constants"
      }
    }
  }
}
