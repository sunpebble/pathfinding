{
  "name": "@pathfinding/types",
  "type": "module",
  "version": "1.0.0",
  "description": "Shared TypeScript types for Pathfinding app",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "tsdown": "0.22.3",
    "typescript": "^6.0.3"
  }
}
