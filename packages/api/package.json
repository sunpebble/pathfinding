{
  "name": "@pathfinding/api",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "predev": "pnpm dlx wrangler@4.107.1 d1 migrations apply pathfinding --local",
    "dev": "flue dev --target cloudflare --port 3000",
    "build": "flue build --target cloudflare",
    "build:lib": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && vitest run --config vitest.d1.config.ts",
    "test:node": "vitest run",
    "test:d1": "vitest run --config vitest.d1.config.ts"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.9",
    "@hono/node-server": "^2.0.10",
    "@hono/zod-validator": "^0.9.0",
    "@pathfinding/database": "workspace:*",
    "@pathfinding/types": "workspace:*",
    "agents": "0.17.4",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.12.31",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "5.20260719.1",
    "@flue/cli": "1.0.0-beta.9",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.12",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
