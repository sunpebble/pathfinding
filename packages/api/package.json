{
  "name": "@pathfinding/api",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "DATABASE_URL=${DATABASE_URL:-mysql://root@127.0.0.1:4000/pathfinding} JWT_SECRET=${JWT_SECRET:-pathfinding-local-dev-secret-change-me} flue dev --target node --port ${PORT:-3000}",
    "build": "flue build --target node",
    "build:lib": "tsdown",
    "flue:dev": "DATABASE_URL=${DATABASE_URL:-mysql://root@127.0.0.1:4000/pathfinding} JWT_SECRET=${JWT_SECRET:-pathfinding-local-dev-secret-change-me} flue dev --target node --port ${PORT:-3000}",
    "flue:build": "flue build --target node",
    "flue:build:cloudflare": "flue build --target cloudflare",
    "start": "tsx dist/server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.9",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@pathfinding/crawler-types": "workspace:*",
    "@pathfinding/database": "workspace:*",
    "@pathfinding/guide-shape": "workspace:*",
    "@pathfinding/types": "workspace:*",
    "agents": "0.17.3",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.12.28",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260707.1",
    "@flue/cli": "1.0.0-beta.9",
    "@types/node": "^26.1.0",
    "tsdown": "^0.22.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
