{
  "name": "@pathfinding/crawler-types",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Shared TypeScript types for the crawler service",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "tsdown": "^0.9.0",
    "typescript": "^5.9.3"
  }
}
