{
  "compilerOptions": {
    "target": "ES2022",
    "rootDir": "../..",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@pathfinding/convex-client/api": ["../../convex/_generated/api"],
      "@pathfinding/convex-client/dataModel": ["../../convex/_generated/dataModel"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "../../packages/convex-client/src/**/*"],
  "exclude": ["node_modules", "dist", "../../convex"]
}
