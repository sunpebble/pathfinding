# Convex
CONVEX_URL=https://convex.kunish.org

# Ollama (AI/LLM)
OLLAMA_BASE_URL=https://ol.svc.kunish.org
OLLAMA_MODEL=gemma3:latest

# Google Gemini (AI/LLM)
GOOGLE_API_KEY=

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=

# Server
PORT=3001

# Stagehand Browser Automation
# Environment: LOCAL for local Chrome, BROWSERBASE for cloud browsers
STAGEHAND_ENV=LOCAL
# Custom OpenAI-compatible API endpoint for Stagehand AI features
STAGEHAND_BASE_URL=https://new-api.kunish.org/v1
# API key for the custom endpoint
STAGEHAND_API_KEY=
# Model name to use (e.g., gpt-4o, gpt-4-turbo, claude-3-5-sonnet)
STAGEHAND_MODEL=gpt-4o
