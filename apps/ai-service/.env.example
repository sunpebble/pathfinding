# Convex
CONVEX_URL=https://convex.kunish.org

# Ollama (AI/LLM)
OLLAMA_BASE_URL=https://ol.svc.kunish.org
OLLAMA_MODEL=gemma3:latest

# Google Gemini (AI/LLM)
GOOGLE_API_KEY=

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=

# Server
PORT=3001

# Stagehand Browser Automation
# Environment: LOCAL for local Chrome, BROWSERBASE for cloud browsers
STAGEHAND_ENV=LOCAL
# Custom OpenAI-compatible API endpoint for Stagehand AI features
STAGEHAND_BASE_URL=https://n.kunish.org/v1
# API key for the custom endpoint
STAGEHAND_API_KEY=
# Model name to use (e.g., claude-opus-4-5-20251101, gpt-4o, claude-3-5-sonnet)
STAGEHAND_MODEL=claude-opus-4-5-20251101

# Kernel.sh Cloud Browser (Anti-Detection)
# API key for Kernel.sh - enables stealth mode and fingerprint randomization
KERNEL_API_KEY=
# Set to 'true' to use legacy browser client (bypasses AntiDetectionBrowserClient)
USE_LEGACY_CLIENT=false
