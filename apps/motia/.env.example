# Motia 服务环境变量配置

# ===== 必需 =====

# TiDB / MySQL 数据库连接 (mafengwo-save.step.ts 使用)
# 格式: mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}
DATABASE_URL=

# Kernel.sh 云浏览器 (马蜂窝爬虫必需, kernel-browser.ts 使用)
# 获取: https://www.kernel.sh/
KERNEL_API_KEY=

# ===== 可选 =====

# API 基础 URL (health.step.ts 检查 API 可达性)
API_BASE_URL=http://localhost:3000

# Ollama 本地 LLM 服务 (ai-chat.step.ts 使用)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest

# OpenAI API (kernel-browser.ts 中 Stagehand AI 提取功能)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
