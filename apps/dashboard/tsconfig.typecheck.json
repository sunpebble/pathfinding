{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "target": "ES2020",
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@pathfinding/convex-client": ["../../packages/convex-client/src"],
      "@pathfinding/convex-client/api": ["../../convex/_generated/api"],
      "@pathfinding/convex-client/dataModel": ["../../convex/_generated/dataModel"]
    },
    "allowJs": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "../../convex"]
}
