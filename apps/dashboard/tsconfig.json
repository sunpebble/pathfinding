{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "target": "ES2020",
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@pathfinding/convex-client/api": ["../../convex/_generated/api"],
      "@pathfinding/convex-client/dataModel": [
        "../../convex/_generated/dataModel"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "../../convex"]
}
