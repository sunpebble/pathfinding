# Supabase Configuration
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
PORT=3001
NODE_ENV=development

# External API Keys
AMAP_API_KEY=your-amap-api-key-here
AMAP_SECRET_KEY=your-amap-secret-key-here

# OpenStreetMap / Overpass API
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Rate Limiting
DEFAULT_RATE_LIMIT_RPS=1
DEFAULT_MAX_CONCURRENT=5

# Crawlee Configuration
CRAWLEE_STORAGE_DIR=./storage
CRAWLEE_HEADLESS=true

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=pathfinding-crawler

# Sentry
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=development

# Logging
LOG_LEVEL=info

# =====================================================
# AI Services Integration
# =====================================================

# Ollama - Local LLM for content extraction and summarization
OLLAMA_BASE_URL=http://localhost:11434
# Available models: gemma3:12b (recommended), gemma3:2b, llama3.2:3b, qwen2.5:14b
OLLAMA_MODEL=gemma3:12b

# n8n - Workflow automation and notifications
N8N_BASE_URL=http://localhost:5678
# API key for n8n (generate in n8n settings)
N8N_API_KEY=your-n8n-api-key-here
# Basic auth for n8n web interface
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
# Webhook URL for external access
N8N_WEBHOOK_URL=http://localhost:5678/
# Encryption key for n8n credentials (generate a random string)
N8N_ENCRYPTION_KEY=your-encryption-key-here

# ComfyUI - AI image generation
COMFYUI_BASE_URL=http://localhost:8188

