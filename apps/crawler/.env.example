# Supabase Configuration
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
PORT=3001
NODE_ENV=development

# External API Keys
AMAP_API_KEY=your-amap-api-key-here
AMAP_SECRET_KEY=your-amap-secret-key-here

# OpenStreetMap / Overpass API
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Rate Limiting
DEFAULT_RATE_LIMIT_RPS=1
DEFAULT_MAX_CONCURRENT=5

# Crawlee Configuration
CRAWLEE_STORAGE_DIR=./storage
CRAWLEE_HEADLESS=true

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=pathfinding-crawler

# Sentry
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=development

# Logging
LOG_LEVEL=info
