name: Pathfinding
options:
  bundleIdPrefix: org.pathfinding
  deploymentTarget:
    iOS: "17.0"
    watchOS: "10.0"
  xcodeVersion: "16.0"
  minimumXcodeGenVersion: "2.0"

configFiles:
  Debug: Config/Debug.xcconfig
  Release: Config/Release.xcconfig
  Staging: Config/Staging.xcconfig

configs:
  Debug: debug
  Release: release
  Staging: release

settings:
  base:
    SWIFT_VERSION: "6.0"
    IPHONEOS_DEPLOYMENT_TARGET: "17.0"
    WATCHOS_DEPLOYMENT_TARGET: "10.0"
    ENABLE_USER_SCRIPT_SANDBOXING: false

targets:
  Pathfinding:
    type: application
    platform: iOS
    sources:
      - Pathfinding
      - path: Shared
        group: Shared
    dependencies:
      - target: PathfindingWatch
      - target: PathfindingWidgets
        embed: true
      - sdk: ARKit.framework
      - sdk: RealityKit.framework
    settings:
      base:
        INFOPLIST_FILE: Pathfinding/Info.plist
        PRODUCT_BUNDLE_IDENTIFIER: org.pathfinding.app$(BUNDLE_ID_SUFFIX)
        MARKETING_VERSION: "1.0.0"
        CURRENT_PROJECT_VERSION: "1"
        DEVELOPMENT_TEAM: ""
        CODE_SIGN_STYLE: Automatic
        ASSETCATALOG_COMPILER_APPICON_NAME: AppIcon
        CODE_SIGN_ENTITLEMENTS: Pathfinding/Pathfinding.entitlements
        # Pass build settings to Info.plist
        INFOPLIST_KEY_CFBundleDisplayName: Pathfinding
    configFiles:
      Debug: Config/Debug.xcconfig
      Release: Config/Release.xcconfig
      Staging: Config/Staging.xcconfig

  PathfindingWatch:
    type: application
    platform: watchOS
    sources:
      - PathfindingWatch
      - path: Shared
        group: Shared
    settings:
      base:
        INFOPLIST_FILE: PathfindingWatch/Info.plist
        PRODUCT_BUNDLE_IDENTIFIER: org.pathfinding.app$(BUNDLE_ID_SUFFIX).watchkitapp
        MARKETING_VERSION: "1.0.0"
        CURRENT_PROJECT_VERSION: "1"
        DEVELOPMENT_TEAM: ""
        CODE_SIGN_STYLE: Automatic
        ASSETCATALOG_COMPILER_APPICON_NAME: AppIcon
        INFOPLIST_KEY_WKCompanionAppBundleIdentifier: org.pathfinding.app$(BUNDLE_ID_SUFFIX)
        INFOPLIST_KEY_CFBundleDisplayName: 探路
    configFiles:
      Debug: Config/Debug.xcconfig
      Release: Config/Release.xcconfig
      Staging: Config/Staging.xcconfig

  PathfindingWidgets:
    type: app-extension
    platform: iOS
    sources:
      - PathfindingWidgets
      - path: Shared
        group: Shared
    settings:
      base:
        INFOPLIST_FILE: PathfindingWidgets/Info.plist
        PRODUCT_BUNDLE_IDENTIFIER: org.pathfinding.app$(BUNDLE_ID_SUFFIX).widgets
        MARKETING_VERSION: "1.0.0"
        CURRENT_PROJECT_VERSION: "1"
        DEVELOPMENT_TEAM: ""
        CODE_SIGN_STYLE: Automatic
        CODE_SIGN_ENTITLEMENTS: PathfindingWidgets/PathfindingWidgets.entitlements
        SKIP_INSTALL: true
        LD_RUNPATH_SEARCH_PATHS: "$(inherited) @executable_path/Frameworks @executable_path/../../Frameworks"
    configFiles:
      Debug: Config/Debug.xcconfig
      Release: Config/Release.xcconfig
      Staging: Config/Staging.xcconfig

schemes:
  Pathfinding-Debug:
    build:
      targets:
        Pathfinding: all
    run:
      config: Debug
      environmentVariables:
        - variable: OS_ACTIVITY_MODE
          value: disable
          isEnabled: false
    test:
      config: Debug
    profile:
      config: Release
    analyze:
      config: Debug
    archive:
      config: Release

  Pathfinding-Staging:
    build:
      targets:
        Pathfinding: all
    run:
      config: Staging
    test:
      config: Staging
    profile:
      config: Staging
    analyze:
      config: Staging
    archive:
      config: Staging

  Pathfinding-Release:
    build:
      targets:
        Pathfinding: all
    run:
      config: Release
    test:
      config: Release
    profile:
      config: Release
    analyze:
      config: Release
    archive:
      config: Release

  PathfindingWatch-Debug:
    build:
      targets:
        PathfindingWatch: all
    run:
      config: Debug
    test:
      config: Debug
    profile:
      config: Release
    analyze:
      config: Debug
    archive:
      config: Release

  PathfindingWatch-Release:
    build:
      targets:
        PathfindingWatch: all
    run:
      config: Release
    test:
      config: Release
    profile:
      config: Release
    analyze:
      config: Release
    archive:
      config: Release
