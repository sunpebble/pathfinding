{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["node", "vitest"],
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["*.ts"],
  "exclude": [
    "_generated/**/*",
    "phoneAuth.ts",
    "notifications.ts",
    "dataQualityReports.ts"
  ]
}
