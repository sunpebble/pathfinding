{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Mobile: Start Metro",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pathfinding/mobile", "start"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting Metro Bundler",
          "endsPattern": "Metro waiting on"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "mobile"
      }
    },
    {
      "label": "Mobile: Run iOS",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pathfinding/mobile", "ios"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["Mobile: Start Metro"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "mobile"
      }
    },
    {
      "label": "Mobile: Run Android",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pathfinding/mobile", "android"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["Mobile: Start Metro"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "mobile"
      }
    },
    {
      "label": "Mobile: Prebuild",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "--filter",
        "@pathfinding/mobile",
        "exec",
        "npx",
        "expo",
        "prebuild",
        "--clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Mobile: TypeCheck",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pathfinding/mobile", "typecheck"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "API: Dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pathfinding/api", "dev"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "tsx watch",
          "endsPattern": "API server running"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "api"
      }
    },
    {
      "label": "API: TypeCheck",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@pathfinding/api", "typecheck"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Supabase: Start",
      "type": "shell",
      "command": "supabase",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "supabase"
      }
    },
    {
      "label": "Supabase: Stop",
      "type": "shell",
      "command": "supabase",
      "args": ["stop"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Supabase: Reset DB",
      "type": "shell",
      "command": "supabase",
      "args": ["db", "reset"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Lint All",
      "type": "shell",
      "command": "pnpm",
      "args": ["lint"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$eslint-stylish"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Full Stack: Start All",
      "dependsOn": ["Supabase: Start", "API: Dev", "Mobile: Start Metro"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
