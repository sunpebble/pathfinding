# Pathfinding Services Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration (Required)
# =============================================================================
# TiDB connection URL (MySQL-compatible)
DATABASE_URL=mysql://root@localhost:4000/pathfinding

# =============================================================================
# Convex Configuration (Deprecated - migrating to TiDB)
# =============================================================================
# CONVEX_DEPLOYMENT=dev:your-deployment-id
# EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_SELF_HOSTED_URL=https://your-convex-instance.example.com
# CONVEX_SELF_HOSTED_ADMIN_KEY=your-admin-key

# =============================================================================
# Tencent Cloud SMS
# =============================================================================
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=1400xxxxxx
TENCENT_SMS_SIGN_NAME=探路
TENCENT_SMS_TEMPLATE_ID=xxxxxxx

# =============================================================================
# Crawler Service Configuration
# =============================================================================
# External API Keys (Optional)
AMAP_API_KEY=your-amap-api-key
AMAP_SECRET_KEY=your-amap-secret-key

# OpenStreetMap / Overpass API
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Rate Limiting
# DEFAULT_RATE_LIMIT_RPS=1
# DEFAULT_MAX_CONCURRENT=5

# Scheduler
# ENABLE_SCHEDULER=true

# Logging
# LOG_LEVEL=info

# =============================================================================
# Observability (Optional)
# =============================================================================
# OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Sentry
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=production

# =============================================================================
# AI Services Configuration
# =============================================================================

# Ollama - Local LLM (Gemma3) for content extraction and summarization
# The Ollama service runs in Docker, default model is gemma3:12b
OLLAMA_MODEL=gemma3:12b

# n8n - Workflow automation for crawl scheduling and notifications
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
# Generate a random 32+ character string for encryption
N8N_ENCRYPTION_KEY=your-random-encryption-key-min-32-chars
# API key (generate in n8n UI: Settings > API)
N8N_API_KEY=your-n8n-api-key

# ComfyUI - AI image generation for travel guide illustrations
# GPU is required for ComfyUI, it will automatically use available NVIDIA GPUs

# Timezone for scheduled jobs
TZ=Asia/Shanghai
