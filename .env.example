# Pathfinding Services Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration (Required)
# =============================================================================
# TiDB connection URL (MySQL-compatible)
DATABASE_URL=mysql://root@localhost:4000/pathfinding

# =============================================================================
# Service Ports (Optional - defaults shown)
# =============================================================================
# PORT=8000              # API service port
# CRAWLER_PORT=3001      # Crawler service port

# =============================================================================
# Tencent Cloud SMS (Required for SMS features)
# =============================================================================
TENCENT_SECRET_ID=<your-tencent-secret-id>
TENCENT_SECRET_KEY=<your-tencent-secret-key>
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=<your-sms-app-id>
TENCENT_SMS_SIGN_NAME=探路
TENCENT_SMS_TEMPLATE_ID=<your-sms-template-id>

# =============================================================================
# Crawler Service Configuration
# =============================================================================
# External API Keys (Optional)
AMAP_API_KEY=<your-amap-api-key>
AMAP_SECRET_KEY=<your-amap-secret-key>

# OpenStreetMap / Overpass API (Optional - defaults to public instance)
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Rate Limiting (Optional)
# DEFAULT_RATE_LIMIT_RPS=1
# DEFAULT_MAX_CONCURRENT=5

# Scheduler (Optional)
# ENABLE_SCHEDULER=true

# Logging (Optional)
# LOG_LEVEL=info

# =============================================================================
# Observability (Optional)
# =============================================================================
# OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Sentry
# SENTRY_DSN=<your-sentry-dsn>
# SENTRY_ENVIRONMENT=production

# =============================================================================
# AI Services Configuration (Required for AI features)
# =============================================================================

# Ollama - Local LLM (Gemma3) for content extraction and summarization
# The Ollama service runs in Docker, default model is gemma3:12b
OLLAMA_MODEL=gemma3:12b

# n8n - Workflow automation for crawl scheduling and notifications (Required for n8n)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<your-n8n-password>
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
# Generate a random 32+ character string for encryption (Required for n8n)
N8N_ENCRYPTION_KEY=<your-random-encryption-key-min-32-chars>
# API key - generate in n8n UI: Settings > API (Optional)
# N8N_API_KEY=<your-n8n-api-key>

# ComfyUI - AI image generation for travel guide illustrations
# GPU is required for ComfyUI, it will automatically use available NVIDIA GPUs

# Timezone for scheduled jobs (Optional)
TZ=Asia/Shanghai
