{
  "name": "pathfinding",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "description": "探路 - Travel planning app with offline-first architecture",
  "author": {
    "name": "kunish",
    "email": "kunish.butt@gmail.com"
  },
  "license": "ISC",
  "keywords": [
    "travel",
    "itinerary",
    "react-native",
    "deno",
    "hono"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "build:packages": "nx run-many -t build --projects=types,utils,constants,crawler-types",
    "build:apps": "nx run-many -t build --projects=api,crawler,dashboard",
    "dev": "nx run-many -t dev --projects=api,crawler,dashboard --parallel=3",
    "dev:api": "nx run api:dev",
    "dev:crawler": "nx run crawler:dev",
    "dev:dashboard": "nx run dashboard:dev",
    "dev:convex": "cd packages/convex && npx convex dev",
    "watch:types": "nx run types:dev",
    "watch:utils": "nx run utils:dev",
    "watch:packages": "nx run-many -t dev --projects=types,utils,constants,crawler-types --parallel=4",
    "ios": "xcodebuild -project apps/ios/Pathfinding/Pathfinding.xcodeproj -scheme Pathfinding-Debug -destination 'platform=iOS Simulator,name=iPhone 17 Pro Max' -derivedDataPath /tmp/pathfinding-build build && xcrun simctl install booted /tmp/pathfinding-build/Build/Products/Debug-iphonesimulator/Pathfinding.app && xcrun simctl launch booted org.pathfinding.app.debug",
    "ios:build": "xcodebuild -project apps/ios/Pathfinding/Pathfinding.xcodeproj -scheme Pathfinding-Debug -destination 'platform=iOS Simulator,name=iPhone 17 Pro Max' build",
    "ios:build:release": "xcodebuild -project apps/ios/Pathfinding/Pathfinding.xcodeproj -scheme Pathfinding-Release -destination 'generic/platform=iOS' build",
    "ios:open": "open apps/ios/Pathfinding/Pathfinding.xcodeproj",
    "ios:gen": "cd apps/ios/Pathfinding && xcodegen generate",
    "ios:clean": "rm -rf /tmp/pathfinding-build && xcodebuild -project apps/ios/Pathfinding/Pathfinding.xcodeproj clean 2>/dev/null || true",
    "ios:sim:list": "xcrun simctl list devices available",
    "ios:sim:boot": "xcrun simctl boot 'iPhone 17 Pro Max' 2>/dev/null || true",
    "ios:sim:shutdown": "xcrun simctl shutdown all",
    "lint": "eslint --fix .",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "test:coverage": "nx run-many -t test -- --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "clean": "nx reset && rm -rf node_modules/.cache .nx/cache",
    "clean:dist": "find . -name 'dist' -type d -not -path './node_modules/*' -exec rm -rf {} + 2>/dev/null || true",
    "clean:all": "pnpm clean:dist && rm -rf node_modules **/node_modules .nx",
    "reset": "pnpm clean:all && pnpm install",
    "health": "pnpm health:api && pnpm health:crawler",
    "health:api": "curl -sf http://localhost:8000/api/health > /dev/null && echo 'API: OK' || echo 'API: DOWN'",
    "health:crawler": "curl -sf http://localhost:3001/health > /dev/null && echo 'Crawler: OK' || echo 'Crawler: DOWN'",
    "docker:api": "docker build -f apps/api/Dockerfile -t pathfinding-api .",
    "docker:crawler": "docker build -f apps/crawler/Dockerfile -t pathfinding-crawler .",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "prepare": "husky",
    "graph": "nx graph",
    "enrich": "curl -X POST http://localhost:3001/api/guides/$npm_config_id/enrich",
    "guides": "curl -s http://localhost:3001/api/guides | jq"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.90",
    "convex": "^1.31.4",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.0.1",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint-react/eslint-plugin": "^2.6.4",
    "@eslint/js": "^9.39.2",
    "@nx/next": "^22.3.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nx": "^22.3.3",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3"
  }
}
