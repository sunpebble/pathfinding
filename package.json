{
  "name": "pathfinding",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "description": "探路 - Travel planning app with offline-first architecture",
  "author": {
    "name": "kunish",
    "email": "kunish.butt@gmail.com"
  },
  "license": "ISC",
  "keywords": [
    "travel",
    "itinerary",
    "react-native",
    "deno",
    "hono"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "build:packages": "nx run-many -t build --projects=types,utils,constants",
    "build:apps": "nx run-many -t build --projects=dashboard",
    "dev": "pnpm dev:db && nx run-many -t dev --projects=@pathfinding/api,dashboard --parallel=2",
    "dev:db": "docker-compose -f docker-compose.dev.yml up -d tidb && pnpm --filter @pathfinding/database dev:ensure-db",
    "dev:api": "pnpm --filter @pathfinding/api dev",

    "dev:dashboard": "nx run dashboard:dev",
    "db:generate": "pnpm --filter @pathfinding/database drizzle-kit generate",
    "db:migrate": "pnpm --filter @pathfinding/database drizzle-kit migrate",
    "db:studio": "pnpm --filter @pathfinding/database drizzle-kit studio",
    "watch:types": "nx run types:dev",
    "watch:utils": "nx run utils:dev",
    "watch:packages": "nx run-many -t dev --projects=types,utils,constants --parallel=3",
    "ios": "bash scripts/ios-launch.sh",
    "ios:clean": "bash scripts/ios-launch.sh --clean",
    "ios:release": "bash scripts/ios-launch.sh --release",
    "ios:build": "bash scripts/ios-launch.sh --build-only",
    "ios:open": "bash scripts/ios-launch.sh --open",
    "ios:gen": "cd apps/ios/Pathfinding && xcodegen generate",
    "ios:setup": "bash scripts/ios-setup.sh",
    "ios:sim:list": "xcrun simctl list devices available",
    "ios:sim:shutdown": "xcrun simctl shutdown all",
    "lint": "eslint .",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "test:coverage": "nx run-many -t test -- --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "clean": "nx reset && rm -rf node_modules/.cache .nx/cache",
    "clean:dist": "find . -name 'dist' -type d -not -path './node_modules/*' -exec rm -rf {} + 2>/dev/null || true",
    "clean:all": "pnpm clean:dist && rm -rf node_modules **/node_modules .nx",
    "reset": "pnpm clean:all && pnpm install",
    "health": "curl -sf http://localhost:3000/health > /dev/null && echo 'API: OK' || echo 'API: DOWN'",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "prepare": "husky",
    "graph": "nx graph"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@types/node": "^22.0.0",
    "drizzle-orm": "^0.44.7",
    "expo-server-sdk": "^6.0.0",
    "jose": "^6.1.3"
  },
  "__dependency_notes__": [
    "Root devDependencies include runtime libraries for repo-level TypeScript scripts under scripts/.",
    "- cheerio: scripts/crawl-mafengwo.ts parses remote HTML.",
    "- playwright: scripts/crawl-mafengwo.ts runs the browser-based Mafengwo crawler required by path-bound WAF cookies."
  ],
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^10.0.1",
    "@nx/next": "^22.5.3",
    "@vitest/coverage-v8": "^4.0.18",
    "cheerio": "^1.2.0",
    "eslint": "^10.0.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nx": "^22.5.3",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": "eslint --fix",
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
